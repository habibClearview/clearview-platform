# ============================================================
# Clearview — environment variables
# ============================================================
# Copy this file to `.env.local` for local development and fill in real values.
# On Vercel these are set in Project → Settings → Environment Variables, scoped
# separately for the "Production" and "Preview" (staging) environments.
#
# See docs/STAGING_AND_ROLLBACK.md for how Production vs Preview (staging) are
# wired to two different Supabase databases.

# --- Supabase (database + auth) -----------------------------------------
# Production env → your LIVE Supabase project.
# Preview env    → your STAGING Supabase project (a separate project).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key   # server-only, never exposed to the browser

# --- Which environment is this? -----------------------------------------
# Drives the on-screen "STAGING" safety banner. Set to:
#   production  on the Vercel Production environment
#   staging     on the Vercel Preview environment (wired to the staging DB)
NEXT_PUBLIC_APP_ENV=production

# --- App URL (used to build invite/redirect links) ----------------------
# Production → https://clearview.habibonifade.com
# Preview    → leave unset to use the auto preview URL, or set the staging URL.
NEXT_PUBLIC_APP_URL=https://clearview.habibonifade.com

# --- Anthropic (Clair support agent, AI briefs) -------------------------
# Optional: features that call Claude degrade gracefully if this is absent.
ANTHROPIC_API_KEY=your-anthropic-api-key
